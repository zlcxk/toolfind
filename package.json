{
  "name": "toolfind",
  "version": "1.0.0",
  "description": "Smart Tool Finder - a lightweight searchable tool directory.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "import:tboxn": "node scripts/import-tboxn.js",
    "import:tboxn:dry": "node scripts/import-tboxn.js --dry-run",
    "icons:fetch": "node scripts/fetch-icons.js",
    "icons:fetch:force": "node scripts/fetch-icons.js --force",
    "data:maintain": "node scripts/maintain-data.js --reclassify-all --compact-category-ids"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "engines": {
    "node": ">=20"
  }
}
